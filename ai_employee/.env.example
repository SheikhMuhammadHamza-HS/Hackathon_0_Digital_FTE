# ============================================
# AI Employee System Configuration
# ============================================

# System Settings
LOG_LEVEL=INFO
ENVIRONMENT=development
DEBUG=false
API_HOST=localhost
API_PORT=8000

# Data Retention (days)
DATA_RETENTION_DAYS=730
TEMP_FILE_RETENTION_DAYS=7
APPROVAL_TIMEOUT_HOURS=4

# File System Paths
VAULT_PATH=/Vault
INBOX_PATH=/Vault/Inbox
NEEDS_ACTION_PATH=/Vault/Needs_Action
PENDING_APPROVAL_PATH=/Vault/Pending_Approval
APPROVED_PATH=/Vault/Approved
REJECTED_PATH=/Vault/Rejected
DONE_PATH=/Vault/Done
LOGS_PATH=/Vault/Logs
REPORTS_PATH=/Vault/Reports
ARCHIVE_PATH=/Vault/Archive

# ============================================
# Odoo ERP Integration
# ============================================
ODOO_URL=http://localhost:8069
ODOO_DB=your_database
ODOO_USERNAME=your_username
ODOO_PASSWORD=your_password
ODOO_TIMEOUT=30
ODOO_MAX_RETRIES=3

# ============================================
# Email Configuration
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=AI Employee <noreply@yourcompany.com>
EMAIL_USE_TLS=true
EMAIL_TIMEOUT=30

# Alternative: SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourcompany.com

# ============================================
# Social Media APIs
# ============================================

# X/Twitter API v2
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret
TWITTER_BEARER_TOKEN=your_bearer_token

# Facebook Graph API
FACEBOOK_PAGE_ID=your_page_id
FACEBOOK_ACCESS_TOKEN=your_page_access_token
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Instagram Basic Display API
INSTAGRAM_USER_ID=your_user_id
INSTAGRAM_ACCESS_TOKEN=your_access_token
INSTAGRAM_CLIENT_ID=your_instagram_client_id
INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret

# LinkedIn APIs
LINKEDIN_CLIENT_ID=your_client_id
LINKEDIN_CLIENT_SECRET=your_client_secret
LINKEDIN_ACCESS_TOKEN=your_access_token
LINKEDIN_COMPANY_ID=your_company_id

# ============================================
# Security & Authentication
# ============================================
SECRET_KEY=your_secret_key_here_change_in_production
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_EXPIRATION_HOURS=24
API_KEY_HEADER=X-API-Key

# ============================================
# Monitoring & Health
# ============================================
HEALTH_CHECK_INTERVAL=60
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=300
MAX_RETRY_ATTEMPTS=3
RETRY_BACKOFF_FACTOR=2

# Prometheus Metrics
METRICS_ENABLED=true
METRICS_PORT=9090

# ============================================
# Performance & Limits
# ============================================
MAX_CONCURRENT_TASKS=10
TASK_TIMEOUT_SECONDS=300
MAX_FILE_SIZE_MB=10
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ============================================
# External Service Timeouts
# ============================================
BANK_API_TIMEOUT=30
SOCIAL_API_TIMEOUT=60
EMAIL_SERVICE_TIMEOUT=30
WEBHOOK_TIMEOUT=10