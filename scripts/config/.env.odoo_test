# AI Employee Test Configuration - Odoo Testing
SECRET_KEY=Test-Secret-Key-12-Chars!
JWT_SECRET_KEY=Test-JWT-Secret-12-Chars!
ENVIRONMENT=test
DRY_RUN=true

# Odoo Configuration - UPDATE THESE WITH YOUR CREDENTIALS
ODOO_URL=http://localhost:8069
ODOO_DB=test_db
ODOO_USERNAME=admin
ODOO_PASSWORD=admin

# Paths
INBOX_PATH=./Inbox
NEEDS_ACTION_PATH=./Needs_Action
DONE_PATH=./Done
LOGS_PATH=./Logs
DASHBOARD_PATH=./Dashboard.md
COMPANY_HANDBOOK_PATH=./Company_Handbook.md

# System Settings
LOG_LEVEL=INFO
DEBUG=false
API_HOST=localhost
API_PORT=8000

# File Processing
FILE_SIZE_LIMIT=10485760
MAX_RETRY_ATTEMPTS=3
DATA_RETENTION_DAYS=730
TEMP_FILE_RETENTION_DAYS=7
APPROVAL_TIMEOUT_HOURS=4