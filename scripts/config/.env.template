# AI Employee - Complete Environment Configuration
# Copy this file to .env and fill in your credentials

# ===========================================
# CORE SYSTEM CONFIGURATION
# ===========================================
SECRET_KEY=your-secret-key-here-12-chars
JWT_SECRET_KEY=your-jwt-secret-key-here-12-chars
ENVIRONMENT=development
DEBUG=false
API_HOST=localhost
API_PORT=8000

# ===========================================
# ODOO ERP INTEGRATION
# ===========================================
# Odoo Community Edition Instance
ODOO_URL=http://localhost:8069
ODOO_DB=your_database_name
ODOO_USERNAME=your_username
ODOO_PASSWORD=your_password
ODOO_TIMEOUT=30
ODOO_MAX_RETRIES=3

# ===========================================
# EMAIL CONFIGURATION
# ===========================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_USE_TLS=true

# ===========================================
# GMAIL API INTEGRATION
# ===========================================
GMAIL_TOKEN={"token": "your_oauth_token", "refresh_token": "your_refresh_token", "client_id": "your_client_id", "client_secret": "your_client_secret"}

# ===========================================
# SOCIAL MEDIA INTEGRATIONS
# ===========================================
# X (Twitter) API v2
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_SECRET=your_x_access_secret
X_BEARER_TOKEN=your_x_bearer_token

# LinkedIn API
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_USER_ID=your_linkedin_user_id

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# Facebook/Instagram
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token
FACEBOOK_PAGE_ID=your_facebook_page_id
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_id

# ===========================================
# FILE PROCESSING
# ===========================================
INBOX_PATH=./Inbox
NEEDS_ACTION_PATH=./Needs_Action
DONE_PATH=./Done
LOGS_PATH=./Logs
DASHBOARD_PATH=./Dashboard.md
COMPANY_HANDBOOK_PATH=./Company_Handbook.md
FILE_SIZE_LIMIT=10485760
MAX_RETRY_ATTEMPTS=3

# ===========================================
# DATA RETENTION
# ===========================================
DATA_RETENTION_DAYS=730
TEMP_FILE_RETENTION_DAYS=7
APPROVAL_TIMEOUT_HOURS=4

# ===========================================
# MONITORING & PERFORMANCE
# ===========================================
LOG_LEVEL=INFO
MONITORING_ENABLED=true
PERFORMANCE_TRACKING=true
CACHE_TTL=3600

# ===========================================
# BACKUP CONFIGURATION
# ===========================================
BACKUP_DIRECTORY=./backups
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
ENCRYPT_BACKUPS=true

# ===========================================
# SECURITY
# ===========================================
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]
RATE_LIMIT_PER_MINUTE=60
SESSION_TIMEOUT=3600

# ===========================================
# EXTERNAL APIS
# ===========================================
# Brave Search API (optional)
BRAVE_API_KEY=your_brave_api_key

# OpenAI API (for AI features)
OPENAI_API_KEY=your_openai_api_key

# Gemini API
GEMINI_API_KEY=your_gemini_api_key

# Claude Code API
CLAUDE_CODE_API_KEY=your_claude_code_api_key

# ===========================================
# TESTING FLAGS
# ===========================================
# Set to 'true' for testing without real operations
DRY_RUN=true

# Enable test mode
TEST_MODE=true