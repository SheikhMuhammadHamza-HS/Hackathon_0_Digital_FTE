# Odoo Real Credentials Template
# COPY THIS FILE TO .env.local AND FILL IN YOUR VALUES

# Odoo Configuration - Real Credentials
ODOO_URL=http://localhost:8069
ODOO_DB=your_database_name
ODOO_USERNAME=your_username
ODOO_PASSWORD=your_password

# Test Mode - Set to 'false' for real operations
DRY_RUN=false
ENVIRONMENT=test

# Keep other existing configurations
SECRET_KEY=Test-Secret-Key-12-Chars!
JWT_SECRET_KEY=Test-JWT-Secret-12-Chars!

# Paths
INBOX_PATH=./Inbox
NEEDS_ACTION_PATH=./Needs_Action
DONE_PATH=./Done
LOGS_PATH=./Logs